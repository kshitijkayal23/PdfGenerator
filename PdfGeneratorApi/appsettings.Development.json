    "ApiGatewayUrl": "https://edgeniusproxy.westeurope.cloudapp.azure.com/ia05/instance/v1/"
  },
  "AllowedOrigins": [
    "http://localhost:3008",
    "http://localhost:3009/"
  ]
}
