{
  "Serilog": {
    "Using": [ "Serilog.Sinks.File", "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Error",
      "Override": {
        "Microsoft": "Error",
        "System": "Error"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "/APMPredictEmailNotificationLog/Api/App-.log",
          "outputTemplate": "{MachineName}\t{Timestamp:yyyy-MM-dd HH:mm:ss.fff}\t[{Level}]\t{ThreadId}\t{SourceContext}\t{Message}{NewLine}",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "buffered": false
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithThreadId", "WithMachineName" ]
  },
  "AuthScheme": "Edge",
  "EdgeModuleConfiguration": {
    "AuthenticationServerUrl": "https://edgedev.apm.abb.local/auth",
    "PDFGeneratorModelBaseUrl": "http://localhost:5000"
  },
  "JWT": {
    "Issuer": "http://localhost:7091",
    "Audience": "http://localhost:7091",
    "SigningKey": "swordfish"
  },
  "AbilityB2C": {
    "Instance": "https://Abilityria05EunBdv.b2clogin.com/",
    "Domain": "Abilityria05EunBdv.onmicrosoft.com",
    "Solution": "",
